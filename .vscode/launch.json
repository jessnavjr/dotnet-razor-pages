{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Launch Web (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-web",
            "program": "${workspaceFolder}/DotNetRazorPages.Web/bin/Debug/net10.0/DotNetRazorPages.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/DotNetRazorPages.Web",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "stopAtEntry": false,
            "justMyCode": true,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        }
    ]
}