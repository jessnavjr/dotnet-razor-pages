{
  "ConnectionStrings": {
    "DefaultConnection": "Server=<server>;Database=<database>;User Id=<username>;Password=<password>;Encrypt=True;TrustServerCertificate=False;"
  },
  "Authorization": {
    "AdminRoles": ["Admin", "SuperAdmin"],
    "EnableTestAuthentication": false,
    "TestUserRole": "User"
  },
  "ActiveDirectory": {
    "Domain": "corp.example.local",
    "Container": "DC=corp,DC=example,DC=local",
    "UseSecureSocketLayer": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AzureKeyVault": {
    "Enabled": false,
    "VaultUri": "https://<your-vault-name>.vault.azure.net/"
  },
  "ElasticStack": {
    "Enabled": false,
    "UseElasticCloud": false,
    "Uris": [
      "https://<elasticsearch-host>:9200"
    ],
    "CloudId": "<elastic-cloud-id>",
    "ApiKey": "<elastic-api-key>",
    "Username": "<elastic-username>",
    "Password": "<elastic-password>",
    "IndexFormat": "dotnetrazorpages-web-{0:yyyy.MM.dd}",
    "DataStream": {
      "Type": "logs",
      "Dataset": "dotnetrazorpages.web",
      "Namespace": "production"
    },
    "Service": {
      "Name": "DotNetRazorPages.Web",
      "Environment": "Production",
      "Version": "1.0.0"
    },
    "Kibana": {
      "BaseUrl": "https://<kibana-host>:5601"
    },
    "Capture": {
      "IncludeScopes": true,
      "RequestBody": false,
      "ResponseBody": false
    }
  },
  "AllowedHosts": "*"
}