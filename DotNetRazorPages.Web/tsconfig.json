{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "types": ["jest"],
    "rootDir": "wwwroot/ts",
    "outDir": "wwwroot/js"
  },
  "include": [
    "wwwroot/ts/**/*.ts"
  ]
}
