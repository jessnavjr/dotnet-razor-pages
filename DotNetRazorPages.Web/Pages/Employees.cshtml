@page
@model EmployeesModel
@{
    ViewData["Title"] = "Employees";
}

<h1 class="mb-3">Employees</h1>

@if (!Model.Employees.Any())
{
    <div class="alert alert-info">No employees found.</div>
}
else
{
    var idSortLink = Model.GetSortLink("id");
    var firstNameSortLink = Model.GetSortLink("name");
    var lastNameSortLink = Model.GetSortLink("name");
    var emailSortLink = Model.GetSortLink("email");
    var jobTitleSortLink = Model.GetSortLink("jobTitle");
    var hireDateSortLink = Model.GetSortLink("hireDate");
    var statusSortLink = Model.GetSortLink("status");

    <form method="get" asp-page="/Employees" class="row g-2 align-items-end mb-3">
        <div class="col-12 col-md-6 col-lg-4">
            <label for="searchTerm" class="form-label">Search</label>
            <input id="searchTerm"
                   name="searchTerm"
                   type="text"
                   value="@Model.SearchTerm"
                   class="form-control"
                   placeholder="First name, last name, or job title" />
        </div>
        <input type="hidden" name="sortBy" value="@Model.SortBy" />
        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
        {
            <div class="col-auto">
                <a asp-page="/Employees"
                   asp-route-sortBy="@Model.SortBy"
                   asp-route-sortDirection="@Model.SortDirection"
                   asp-route-pageSize="@Model.PageSize"
                   class="btn btn-outline-secondary">
                    Clear
                </a>
            </div>
        }
    </form>

    <div class="d-flex justify-content-end gap-2 mb-3">
        <a asp-page="/EmployeeDetail" class="btn btn-primary">
            Create Employee
        </a>
        <a asp-page="/Employees"
           asp-page-handler="ExportCsv"
           asp-route-sortBy="@Model.SortBy"
           asp-route-sortDirection="@Model.SortDirection"
           asp-route-searchTerm="@Model.SearchTerm"
           class="btn btn-outline-primary">
            Export CSV
        </a>
        <a asp-page="/Employees"
           asp-page-handler="ExportJson"
           asp-route-sortBy="@Model.SortBy"
           asp-route-sortDirection="@Model.SortDirection"
           asp-route-searchTerm="@Model.SearchTerm"
           class="btn btn-outline-primary">
            Export JSON
        </a>
    </div>

    @await Html.PartialAsync("_Pagination", Model.Pagination)

    <div class="table-responsive-xl">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th><a href="@idSortLink" class="link-dark text-decoration-none">@Model.GetDisplayName(nameof(DotNetRazorPages.Services.Models.EmployeeDto.Id))@Model.GetSortIndicator("id")</a></th>
                    <th><a href="@firstNameSortLink" class="link-dark text-decoration-none">@Model.GetDisplayName(nameof(DotNetRazorPages.Services.Models.EmployeeDto.FirstName))@Model.GetSortIndicator("name")</a></th>
                    <th><a href="@lastNameSortLink" class="link-dark text-decoration-none">@Model.GetDisplayName(nameof(DotNetRazorPages.Services.Models.EmployeeDto.LastName))@Model.GetSortIndicator("name")</a></th>
                    <th><a href="@emailSortLink" class="link-dark text-decoration-none">@Model.GetDisplayName(nameof(DotNetRazorPages.Services.Models.EmployeeDto.Email))@Model.GetSortIndicator("email")</a></th>
                    <th><a href="@jobTitleSortLink" class="link-dark text-decoration-none">@Model.GetDisplayName(nameof(DotNetRazorPages.Services.Models.EmployeeDto.JobTitle))@Model.GetSortIndicator("jobTitle")</a></th>
                    <th><a href="@hireDateSortLink" class="link-dark text-decoration-none">@Model.GetDisplayName(nameof(DotNetRazorPages.Services.Models.EmployeeDto.HireDate))@Model.GetSortIndicator("hireDate")</a></th>
                    <th><a href="@statusSortLink" class="link-dark text-decoration-none">@Model.GetDisplayName(nameof(DotNetRazorPages.Services.Models.EmployeeDto.IsActive))@Model.GetSortIndicator("status")</a></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var employee in Model.Employees)
            {
                <tr>
                    <td>
                        <a asp-page="/EmployeeDetail" asp-route-id="@employee.Id">@employee.Id</a>
                    </td>
                    <td>
                        <a asp-page="/EmployeeDetail" asp-route-id="@employee.Id">@employee.FirstName</a>
                    </td>
                    <td>@employee.LastName</td>
                    <td>@employee.Email</td>
                    <td>@employee.JobTitle</td>
                    <td>@employee.HireDate.ToString("yyyy-MM-dd")</td>
                    <td>@(employee.IsActive ? "Active" : "Inactive")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

}