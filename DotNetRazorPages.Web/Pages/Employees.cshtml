@page
@model EmployeesModel
@{
    ViewData["Title"] = "Employees";
}

<h1 class="mb-3">Employees</h1>

@if (!Model.Employees.Any())
{
    <div class="alert alert-info">No employees found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle" data-module="employees-age">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Age</th>
                    <th>Email</th>
                    <th>Job Title</th>
                    <th>Hire Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var employee in Model.Employees)
            {
                <tr>
                    <td>@employee.Id</td>
                    <td>@employee.FirstName @employee.LastName</td>
                    <td data-employee-date="@employee.HireDate.ToString("yyyy-MM-dd")" data-role="employee-age">--</td>
                    <td>@employee.Email</td>
                    <td>@employee.JobTitle</td>
                    <td>@employee.HireDate.ToString("yyyy-MM-dd")</td>
                    <td>@(employee.IsActive ? "Active" : "Inactive")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}