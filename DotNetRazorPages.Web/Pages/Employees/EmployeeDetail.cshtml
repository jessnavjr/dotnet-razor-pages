@page "/EmployeeDetail/{id:int?}"
@model DotNetRazorPages.Web.Pages.EmployeeDetailModel
@{
    ViewData["Title"] = Model.IsCreateMode ? "Create Employee" : "Employee Details";
}

<article class="employee-detail-page">
    <header class="mb-3">
        <h1 class="mb-0">@ViewData["Title"]</h1>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="alert alert-success" role="status">@Model.StatusMessage</section>
    }

    <form method="post" asp-page-handler="@(Model.IsCreateMode ? "Create" : "Update")" class="mb-3">
        <input type="hidden" asp-for="Input.Id" />

        <section asp-validation-summary="ModelOnly" class="text-danger mb-2"></section>

        <section class="mb-3">
            <label asp-for="Input.FirstName" class="form-label"></label>
            <input asp-for="Input.FirstName" class="form-control" />
            <span asp-validation-for="Input.FirstName" class="text-danger"></span>
        </section>

        <section class="mb-3">
            <label asp-for="Input.LastName" class="form-label"></label>
            <input asp-for="Input.LastName" class="form-control" />
            <span asp-validation-for="Input.LastName" class="text-danger"></span>
        </section>

        <section class="mb-3">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email"
                   class="form-control"
                   type="email"
                   autocomplete="email"
                   pattern="^[^\s\x40]+\x40[^\s\x40]+\.[^\s\x40]+$"
                   title="Enter a valid email address (example: name at company dot com)."
                   aria-describedby="emailFormatFeedback" />
            <p id="emailFormatFeedback" class="invalid-feedback mb-0">
                Please enter a valid email address format.
            </p>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </section>

        <section class="mb-3">
            <label asp-for="Input.JobTitle" class="form-label"></label>
            <input asp-for="Input.JobTitle" class="form-control" />
            <span asp-validation-for="Input.JobTitle" class="text-danger"></span>
        </section>

        <section class="mb-3">
            <label asp-for="Input.HireDate" class="form-label"></label>
            <input asp-for="Input.HireDate" class="form-control" type="date" />
            <span asp-validation-for="Input.HireDate" class="text-danger"></span>
        </section>

        <section class="form-check mb-3">
            <input asp-for="Input.IsActive" class="form-check-input" />
            <label asp-for="Input.IsActive" class="form-check-label"></label>
        </section>

        <footer class="d-flex gap-2">
            <button id="saveEmployeeButton" type="submit" class="btn btn-primary">@(Model.IsCreateMode ? "Create" : "Save")</button>
            @if (!Model.IsCreateMode)
            {
                <button type="submit"
                        asp-page-handler="Delete"
                        class="btn btn-danger"
                        onclick="return confirm('Delete this employee record?');">
                    Delete
                </button>
                <a asp-page-handler="ExportPdf"
                   asp-route-id="@Model.Input.Id"
                   class="btn btn-outline-secondary ms-auto">
                    <i class="bi bi-file-earmark-arrow-down"></i> Export to PDF
                </a>
            }
            <a asp-page="/Employees/Employees" class="btn btn-outline-secondary @(Model.IsCreateMode ? "ms-auto" : "")">Back to Employees</a>
        </footer>
    </form>
</article>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const emailField = document.getElementById('Input_Email');
            const emailFeedback = document.getElementById('emailFormatFeedback');
            if (!emailField) {
                return;
            }

            const emailPattern = /^[^\s\x40]+\x40[^\s\x40]+\.[^\s\x40]+$/;
            const emailErrorMessage = 'Please enter a valid email address (example: name at company dot com).';

            const validateEmailFormat = () => {
                const value = (emailField.value || '').trim();

                // Let required validation handle empty values.
                if (!value) {
                    emailField.setCustomValidity('');
                    emailField.classList.remove('is-invalid');
                    return;
                }

                const isValid = emailPattern.test(value);
                emailField.setCustomValidity(isValid ? '' : emailErrorMessage);
                emailField.classList.toggle('is-invalid', !isValid);

                if (!isValid && emailFeedback) {
                    emailFeedback.textContent = emailErrorMessage;
                }
            };

            emailField.addEventListener('input', validateEmailFormat);
            emailField.addEventListener('change', validateEmailFormat);
            emailField.addEventListener('blur', validateEmailFormat);
            validateEmailFormat();
        })();

    </script>
    <script>
        (() => {
            const isCreateMode = @Model.IsCreateMode.ToString().ToLowerInvariant();
            if (isCreateMode) {
                return;
            }

            const form = document.querySelector('form[asp-page-handler], form[method="post"]');
            const saveButton = document.getElementById('saveEmployeeButton');
            if (!form || !saveButton) {
                return;
            }

            const trackedFieldSelectors = [
                '#Input_FirstName',
                '#Input_LastName',
                '#Input_Email',
                '#Input_JobTitle',
                '#Input_HireDate',
                '#Input_IsActive'
            ];

            const trackedFields = trackedFieldSelectors
                .map(selector => document.querySelector(selector))
                .filter(field => field !== null);

            const getFieldValue = (field) => {
                if (field.type === 'checkbox') {
                    return field.checked ? 'true' : 'false';
                }

                return field.value ?? '';
            };

            const originalValues = new Map();
            trackedFields.forEach(field => {
                originalValues.set(field.id, getFieldValue(field));
            });

            const updateSaveButtonState = () => {
                const hasChanges = trackedFields.some(field => {
                    const original = originalValues.get(field.id) ?? '';
                    return getFieldValue(field) !== original;
                });

                saveButton.disabled = !hasChanges;
            };

            trackedFields.forEach(field => {
                field.addEventListener('input', updateSaveButtonState);
                field.addEventListener('change', updateSaveButtonState);
            });

            updateSaveButtonState();
        })();
    </script>
}
