@model DotNetRazorPages.Web.Models.PaginationModel

<form method="get" action="@Model.PagePath" class="row g-2 align-items-center mb-3">
    <input type="hidden" name="pageNumber" value="1" />
    @foreach (var parameter in Model.AdditionalQueryParameters)
    {
        if (!string.Equals(parameter.Key, "pageNumber", StringComparison.OrdinalIgnoreCase) &&
            !string.Equals(parameter.Key, "pageSize", StringComparison.OrdinalIgnoreCase))
        {
            <input type="hidden" name="@parameter.Key" value="@parameter.Value" />
        }
    }

    <div class="col-auto">
        <label for="pageSize" class="col-form-label">Rows per page</label>
    </div>

    <div class="col-auto">
        <select id="pageSize" name="pageSize" class="form-select" onchange="this.form.submit()">
            @foreach (var option in Model.PageSizeOptions)
            {
                if (option == Model.PageSize)
                {
                    <option value="@option" selected>@option</option>
                }
                else
                {
                    <option value="@option">@option</option>
                }
            }
        </select>
    </div>
</form>

<nav aria-label="Pagination">
    <ul class="pagination">
        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
            <a class="page-link" href="@Model.BuildPageUrl(Model.PageNumber - 1)">Previous</a>
        </li>
        <li class="page-item disabled">
            <span class="page-link">Page @Model.PageNumber of @Model.TotalPages</span>
        </li>
        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
            <a class="page-link" href="@Model.BuildPageUrl(Model.PageNumber + 1)">Next</a>
        </li>
    </ul>
</nav>