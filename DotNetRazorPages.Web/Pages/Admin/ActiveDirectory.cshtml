@page "/ActiveDirectory"
@model ActiveDirectoryModel
@{
    ViewData["Title"] = "Active Directory";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-10">
            <h1 class="mb-3">
                <i class="bi bi-diagram-3"></i> Active Directory Search
            </h1>
            <p class="text-muted">Search an on-prem Windows Active Directory user and review core account information and security group memberships.</p>

            <div class="card shadow-sm mb-4">
                <div class="card-header app-admin-header">Search User</div>
                <div class="card-body">
                    <form method="post" class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Username" class="form-label">Username</label>
                            <input asp-for="Username" class="form-control" placeholder="sAMAccountName, UPN, or CN" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search"></i> Search Active Directory
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-warning" role="alert">
                    @Model.ErrorMessage
                </div>
            }

            @if (Model.UserResult is not null)
            {
                <div class="card mb-4">
                    <div class="card-header app-admin-header-soft">User Information</div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-3">Username</dt>
                            <dd class="col-sm-9">@Model.UserResult.Username</dd>

                            <dt class="col-sm-3">Display Name</dt>
                            <dd class="col-sm-9">@Model.UserResult.DisplayName</dd>

                            <dt class="col-sm-3">First Name</dt>
                            <dd class="col-sm-9">@Model.UserResult.GivenName</dd>

                            <dt class="col-sm-3">Last Name</dt>
                            <dd class="col-sm-9">@Model.UserResult.Surname</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.UserResult.Email</dd>

                            <dt class="col-sm-3">UPN</dt>
                            <dd class="col-sm-9">@Model.UserResult.UserPrincipalName</dd>

                            <dt class="col-sm-3">Account Status</dt>
                            <dd class="col-sm-9">
                                @if (Model.UserResult.Enabled)
                                {
                                    <span class="badge bg-success">Enabled</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Disabled</span>
                                }
                            </dd>

                            <dt class="col-sm-3">Distinguished Name</dt>
                            <dd class="col-sm-9"><code>@Model.UserResult.DistinguishedName</code></dd>
                        </dl>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header app-admin-header">Security Group Memberships</div>
                    <div class="card-body">
                        @if (Model.UserResult.SecurityGroups.Count == 0)
                        {
                            <p class="mb-0 text-muted">No security groups found for this user.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Group Name</th>
                                            <th>Distinguished Name</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var group in Model.UserResult.SecurityGroups)
                                        {
                                            <tr>
                                                <td>@group.Name</td>
                                                <td><code>@group.DistinguishedName</code></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (Model.SearchAttempted && string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-info" role="alert">No user matched your search.</div>
            }
        </div>
    </div>
</div>
