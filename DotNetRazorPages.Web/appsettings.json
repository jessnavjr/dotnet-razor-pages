{
  "ConnectionStrings": {
  
  },
  "Authorization": {
    "AdminRoles": ["Admin", "SuperAdmin"],
    "EnableTestAuthentication": true,
    "TestUserRole": "User"
  },
  "ActiveDirectory": {
    "Domain": "corp.example.local",
    "Container": "DC=corp,DC=example,DC=local",
    "UseSecureSocketLayer": false,
    "BindUsername": "",
    "BindPassword": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AzureKeyVault": {
    "Enabled": false,
    "VaultUri": ""
  },
  "ElasticStack": {
    "Enabled": false,
    "UseElasticCloud": false,
    "Uris": [
      "http://localhost:9200"
    ],
    "CloudId": "",
    "ApiKey": "",
    "Username": "",
    "Password": "",
    "IndexFormat": "dotnetrazorpages-web-production-{0:yyyy.MM.dd}",
    "DataStream": {
      "Type": "logs",
      "Dataset": "dotnetrazorpages.web",
      "Namespace": "production"
    },
    "Service": {
      "Name": "DotNetRazorPages.Web",
      "Environment": "Production",
      "Version": "1.0.0"
    },
    "Kibana": {
      "BaseUrl": "http://localhost:5601"
    },
    "Capture": {
      "IncludeScopes": true,
      "RequestBody": false,
      "ResponseBody": false
    }
  },
  "AllowedHosts": "*"
}
